{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Flash",
            "type": "shell",
            "command": "openocd",
            "args": [
                "-f",
                "interface/stlink.cfg",
                "-f",
                "target/stm32l4x.cfg",
                "-c",
                "program build/Release/${workspaceFolderBasename}.elf verify reset exit"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": "build"
        },
        {
            "label": "Build and Flash",
            "type": "shell",
            "command": "cube-cmake --build build/Release -- && openocd -f interface/stlink.cfg -f target/stm32l4x.cfg -c \"program build/Release/${workspaceFolderBasename}.elf verify reset exit\"",
            "options": {
                "cwd": "${workspaceFolder}",
                "shell": {
                    "executable": "cmd.exe",
                    "args": [
                        "/d",
                        "/c"
                    ]
                }
            },
            "group": "build",
            "problemMatcher": []
        }
    ]
}